(function () {
  'use strict';

  // 🔐 ===== ADVANCED LOCK SYSTEM =====
  const SECRET = "KOWSER_ULTRA_2026";

  function getFingerprint() {
    return btoa(
      navigator.userAgent +
      screen.width +
      screen.height +
      navigator.language
    );
  }

  function checkAccess() {
    const savedKey = localStorage.getItem("apollo_secure");
    const currentFP = getFingerprint();

    if (!savedKey) {
      localStorage.setItem("apollo_secure", SECRET + "_" + currentFP);
      console.log("✅ Device Registered");
      return true;
    }

    if (savedKey !== SECRET + "_" + currentFP) {
      console.clear();
      console.log("%c❌ Unauthorized Copy Detected", "color:red;font-size:16px;");
      return false;
    }

    return true;
  }

  // ⛔ Domain Lock (only allow apollo)
  if (!location.hostname.includes("apollo")) {
    console.log("⛔ Wrong Website");
    return;
  }

  // ⛔ Time Expiry (7 days)
  const now = Date.now();
  const firstRun = localStorage.getItem("apollo_time");

  if (!firstRun) {
    localStorage.setItem("apollo_time", now);
  } else {
    const diff = now - parseInt(firstRun);
    const days = diff / (1000 * 60 * 60 * 24);
    if (days > 7) {
      console.log("⛔ Script Expired");
      return;
    }
  }

  // ⛔ DevTools Detection
  setInterval(() => {
    if (window.outerWidth - window.innerWidth > 200) {
      document.body.innerHTML = "";
    }
  }, 1000);

  // ⛔ Access check
  if (!checkAccess()) return;

  // ── MAIN FUNCTION ─────────────────────────────
  const copied = new Set();

  function toClip(text) {
    navigator.clipboard.writeText(text).catch(() => {});
  }

  function handleEmailEl(el) {
    const email = el.textContent.trim().toLowerCase();

    if (!email.includes('@')) return;
    if (email.includes('apollo.io') || email.includes('example.com')) return;

    if (copied.has(email)) return;
    copied.add(email);

    toClip(email);

    console.log("%c✔ Email:", "color:#00ffcc;", email);
  }

  function scanExisting() {
    document
      .querySelectorAll('[data-testid="EditableEmailCell__link"]')
      .forEach(handleEmailEl);
  }

  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      mutation.addedNodes.forEach(node => {
        if (node.nodeType !== 1) return;

        if (node.matches?.('[data-testid="EditableEmailCell__link"]')) {
          handleEmailEl(node);
          return;
        }

        node
          .querySelectorAll?.('[data-testid="EditableEmailCell__link"]')
          .forEach(handleEmailEl);
      });
    }
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });

  scanExisting();

  console.log("%c🔒 Ultra Protected Apollo Catcher Active", "color:#00ffcc;font-weight:bold;");

})();
